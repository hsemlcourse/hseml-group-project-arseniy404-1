   "source": [
    "print(\"\\nДоступные колонки:\")\n",
    "print(train_df.columns.tolist())\n",
    "\n",
    "target = 'rating'\n",
    "\n",
    "# Исключаем: id-колонки, текстовые, целевой признак\n",
    "exclude_cols = ['contestId', 'index', 'name', 'tags', 'tags_list', 'top_tag', 'statement', target]\n",
    "\n",
    "feature_cols = [col for col in train_df.columns if col not in exclude_cols]\n",
    "\n",
    "print(f\"\\nЦелевой признак: {target}\")\n",
    "print(f\"\\nПризнаки для модели ({len(feature_cols)} шт.):\")\n",
    "for i, col in enumerate(feature_cols, 1):\n",
    "    print(f\"  {i}. {col}\")\n",
    "\n",
    "# Проверяем, что все признаки есть в валидационной выборке\n",
    "missing_in_val = [col for col in feature_cols if col not in val_df.columns]\n",
    "if missing_in_val:\n",
    "    print(f\"\\nВнимание! В валидации нет признаков: {missing_in_val}\")\n"
   ]
